# Copy this to /etc/labreserve/hosts.yml and populate it.
# labreserve init will manage this file automatically when you add machines.
#
# ansible_user must match the shared group account on each machine.
# Passwords are NOT stored here — they live in the vault.

all:
  hosts:
    lab-machine-01:
      ansible_host: 192.168.1.10
      ansible_user: labuser
    lab-machine-02:
      ansible_host: 192.168.1.11
      ansible_user: labuser
    lab-machine-03:
      ansible_host: 192.168.1.12
      ansible_user: labuser
